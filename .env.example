LINE_CHANNEL_SECRET=your_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token

ANTHROPIC_API_KEY=your_anthropic_api_key

GEMINI_API_KEY=your_gemini_api_key

ODOO_URL=https://your-odoo-instance.com
ODOO_API_TOKEN=your_odoo_api_token

MANAGER_LINE_USER_ID=Uxxxxxxxxx   # LINE userId менеджера для уведомлений
MANAGER_WORK_START=10
MANAGER_WORK_END=18

SOCIALS_URL=https://example.com/socials

# ── BotsAPI connection ────────────────────────────────────────────────────────
BOTS_API_URL=http://localhost:8000
BOTS_API_KEY=your_bots_api_key

# ── Odoo Purchase Webhook ─────────────────────────────────────────────────────
# Секрет для защиты POST /odoo/purchase — передаётся в заголовке X-API-Key
WEBHOOK_SECRET=your_webhook_secret_here

# ── Twilio (OTP SMS) ──────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE=+1234567890

# ── Meta Ads Manager ──────────────────────────────────────────────────────────
META_ADS_PIXEL_ID=your_meta_pixel_id
META_ADS_ACCESS_TOKEN=your_meta_ads_access_token
